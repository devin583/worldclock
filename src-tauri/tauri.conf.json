{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorldClock",
  "version": "0.1.0",
  "identifier": "com.worldclock.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WorldClock",
        "width": 416,
        "height": 200,
        "minWidth": 320,
        "minHeight": 160,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    }
  },
  "plugins": {
    "autostart": {
      "macosExtraArgs": []
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
